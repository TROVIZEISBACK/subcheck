# Copy this file to .env.local and fill in real values. .env.local is gitignored.
# NEVER commit real credentials.

# ---- Database (PostgreSQL) ----
# A Postgres connection string. Examples:
#   Local:  postgresql://postgres:postgres@localhost:5432/subcheck
#   Neon:   postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/subcheck?sslmode=require
# TLS is enabled automatically for non-localhost hosts.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/subcheck

# ---- Plaid (used in the Plaid integration step) ----
# Dashboard > Team Settings > Keys. Start in the free "sandbox" environment.
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox

# A random 32+ char string used to encrypt Plaid access tokens at rest.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-string

# Base URL of this app (used for Plaid redirect/webhook). Local default:
NEXT_PUBLIC_APP_URL=http://localhost:3000
